    "# Install required libraries\n",
    "!pip install bertopic nltk gensim scikit-learn sentence-transformers umap-learn hdbscan --upgrade\n",
    "\n",
    "# Imports\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import random\n",
    "import re\n",
    "\n",
    "from sklearn.datasets import fetch_20newsgroups\n",
    "\n",
    "import nltk\n",
    "from nltk.corpus import stopwords\n",
    "\n",
    "from gensim.models.coherencemodel import CoherenceModel\n",
    "from gensim.corpora.dictionary import Dictionary\n",
    "\n",
    "from bertopic import BERTopic\n",
    "\n",
    "nltk.download('stopwords')\n",
    "\n",
    "# -------------------------------\n",
    "# Load Dataset (2000 samples)\n",
    "# -------------------------------\n",
    "data = fetch_20newsgroups(remove=('headers', 'footers', 'quotes'))\n",
    "documents = random.sample(data.data, 2000)\n",
    "\n",
    "# -------------------------------\n",
    "# Preprocessing\n",
    "# -------------------------------\n",
    "stop_words = set(stopwords.words('english'))\n",
    "\n",
    "def preprocess(text):\n",
    "    text = text.lower()\n",
    "    text = re.sub(r'\\W+', ' ', text)\n",
    "    words = text.split()\n",
    "    words = [w for w in words if w not in stop_words]\n",
    "    return \" \".join(words)\n",
    "\n",
    "processed_docs = [preprocess(doc) for doc in documents]\n",
    "\n",
    "# -------------------------------\n",
    "# Prepare for coherence\n",
    "# -------------------------------\n",
    "texts = [doc.split() for doc in processed_docs]\n",
    "dictionary = Dictionary(texts)\n",
    "\n",
    "def compute_coherence(topic_model):\n",
    "    topics = []\n",
    "    for topic_id in topic_model.get_topics():\n",
    "        if topic_id == -1:\n",
    "            continue\n",
    "        words = [word for word, _ in topic_model.get_topic(topic_id)]\n",
    "        topics.append(words[:10])\n",
    "\n",
    "    coherence_model = CoherenceModel(\n",
    "        topics=topics,\n",
    "        texts=texts,\n",
    "        dictionary=dictionary,\n",
    "        coherence='c_v'\n",
    "    )\n",
    "    return coherence_model.get_coherence()\n",
    "\n",
    "# -------------------------------\n",
    "# BERTopic (Default Model)\n",
    "# -------------------------------\n",
    "topic_model = BERTopic(nr_topics=10, verbose=True)\n",
    "\n",
    "topics, probs = topic_model.fit_transform(processed_docs)\n",
    "\n",
    "# -------------------------------\n",
    "# Display Topics\n",
    "# -------------------------------\n",
    "print(\"\\nGenerated Topics:\\n\")\n",
    "print(topic_model.get_topic_info())\n",
    "\n",
    "# -------------------------------\n",
    "# Coherence Score for K=10\n",
    "# -------------------------------\n",
    "coherence_score = compute_coherence(topic_model)\n",
    "print(f\"\\nCoherence Score (K=10): {coherence_score}\")\n",
    "\n",
    "# -------------------------------\n",
    "# Find Optimal K\n",
    "# -------------------------------\n",
    "k_values = [5, 7, 10, 12, 15]\n",
    "scores = []\n",
    "\n",
    "for k in k_values:\n",
    "    print(f\"\\nTraining for K={k} ...\")\n",
    "\n",
    "    model = BERTopic(nr_topics=k, verbose=False)\n",
    "\n",
    "    topics, probs = model.fit_transform(processed_docs)\n",
    "    score = compute_coherence(model)\n",
    "    scores.append(score)\n",
    "\n",
    "    print(f\"K={k}, Coherence={score}\")\n",
    "\n",
    "# -------------------------------\n",
    "# Best K\n",
    "# -------------------------------\n",
    "best_k = k_values[np.argmax(scores)]\n",
    "print(f\"\\nOptimal K: {best_k}\")\n",
    "\n",
    "# -------------------------------\n",
    "# Retrain with Best K\n",
    "# -------------------------------\n",
    "final_model = BERTopic(nr_topics=best_k, verbose=True)\n",
    "\n",
    "topics, probs = final_model.fit_transform(processed_docs)\n",
    "\n",
    "print(\"\\nFinal Topics:\\n\")\n",
    "print(final_model.get_topic_info())\n",
    "\n",
    "# -------------------------------\n",
    "# Visualizations\n",
    "# -------------------------------\n",
    "final_model.visualize_topics()\n",
    "final_model.visualize_barchart()"
   ]
  },
