   "source": [
    "# Install required libraries\n",
    "!pip install bertopic nltk gensim scikit-learn sentence-transformers umap-learn hdbscan --upgrade\n",
    "\n",
    "# Imports\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import random\n",
    "import re\n",
    "\n",
    "from sklearn.datasets import fetch_20newsgroups\n",
    "from sklearn.cluster import DBSCAN\n",
    "\n",
    "import nltk\n",
    "from nltk.corpus import stopwords\n",
    "\n",
    "from gensim.models.coherencemodel import CoherenceModel\n",
    "from gensim.corpora.dictionary import Dictionary\n",
    "\n",
    "from bertopic import BERTopic\n",
    "from sentence_transformers import SentenceTransformer\n",
    "\n",
    "nltk.download('stopwords')\n",
    "\n",
    "# -------------------------------\n",
    "# Load Dataset (2000 samples)\n",
    "# -------------------------------\n",
    "data = fetch_20newsgroups(remove=('headers', 'footers', 'quotes'))\n",
    "documents = random.sample(data.data, 2000)\n",
    "\n",
    "# -------------------------------\n",
    "# Preprocessing\n",
    "# -------------------------------\n",
    "stop_words = set(stopwords.words('english'))\n",
    "\n",
    "def preprocess(text):\n",
    "    text = text.lower()\n",
    "    text = re.sub(r'\\W+', ' ', text)\n",
    "    words = text.split()\n",
    "    words = [w for w in words if w not in stop_words]\n",
    "    return \" \".join(words)\n",
    "\n",
    "processed_docs = [preprocess(doc) for doc in documents]\n",
    "\n",
    "# -------------------------------\n",
    "# Prepare for coherence\n",
    "# -------------------------------\n",
    "texts = [doc.split() for doc in processed_docs]\n",
    "dictionary = Dictionary(texts)\n",
    "\n",
    "def compute_coherence(topic_model):\n",
    "    topics = []\n",
    "    for topic_id in topic_model.get_topics():\n",
    "        if topic_id == -1:\n",
    "            continue\n",
    "        words = [word for word, _ in topic_model.get_topic(topic_id)]\n",
    "        topics.append(words[:10])\n",
    "\n",
    "    coherence_model = CoherenceModel(\n",
    "        topics=topics,\n",
    "        texts=texts,\n",
    "        dictionary=dictionary,\n",
    "        coherence='c_v'\n",
    "    )\n",
    "    return coherence_model.get_coherence()\n",
    "\n",
    "# =====================================================\n",
    "# 🔷 Q4.1 DEFAULT BERTopic MODEL\n",
    "# =====================================================\n",
    "print(\"\\n--- Default BERTopic Model ---\")\n",
    "\n",
    "default_model = BERTopic(verbose=True)\n",
    "topics_default, probs_default = default_model.fit_transform(processed_docs)\n",
    "\n",
    "print(default_model.get_topic_info())\n",
    "\n",
    "default_coherence = compute_coherence(default_model)\n",
    "print(f\"\\nDefault BERTopic Coherence: {default_coherence}\")\n",
    "\n",
    "# =====================================================\n",
    "# 🔷 Q4.1 CUSTOM BERTopic MODEL\n",
    "# =====================================================\n",
    "print(\"\\n--- Custom BERTopic Model ---\")\n",
    "\n",
    "# Custom embedding model\n",
    "embedding_model = SentenceTransformer('all-MiniLM-L6-v2')\n",
    "\n",
    "# Custom clustering model (DBSCAN instead of HDBSCAN)\n",
    "cluster_model = DBSCAN(eps=0.5, min_samples=5)\n",
    "\n",
    "custom_model = BERTopic(\n",
    "    embedding_model=embedding_model,\n",
    "    hdbscan_model=cluster_model,   # replacing default clustering\n",
    "    verbose=True\n",
    ")\n",
    "\n",
    "topics_custom, probs_custom = custom_model.fit_transform(processed_docs)\n",
    "\n",
    "print(custom_model.get_topic_info())\n",
    "\n",
    "custom_coherence = compute_coherence(custom_model)\n",
    "print(f\"\\nCustom BERTopic Coherence: {custom_coherence}\")\n",
    "\n",
    "# =====================================================\n",
    "# 🔷 Q4.3 VISUALIZATIONS\n",
    "# =====================================================\n",
    "print(\"\\n--- Default Model Visualization ---\")\n",
    "default_model.visualize_topics()\n",
    "default_model.visualize_barchart()\n",
    "\n",
    "print(\"\\n--- Custom Model Visualization ---\")\n",
    "custom_model.visualize_topics()\n",
    "custom_model.visualize_barchart()"
   ]
