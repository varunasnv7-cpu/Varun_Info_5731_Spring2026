        "# Install required libraries\n",
        "!pip install nltk gensim scikit-learn matplotlib\n",
        "\n",
        "# Imports\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import random\n",
        "import re\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "from sklearn.datasets import fetch_20newsgroups\n",
        "from sklearn.feature_extraction.text import CountVectorizer\n",
        "from sklearn.decomposition import LatentDirichletAllocation, TruncatedSVD\n",
        "\n",
        "import nltk\n",
        "from nltk.corpus import stopwords\n",
        "\n",
        "from gensim.models.coherencemodel import CoherenceModel\n",
        "from gensim.corpora.dictionary import Dictionary\n",
        "\n",
        "nltk.download('stopwords')\n",
        "\n",
        "# Load dataset (2000 random samples)\n",
        "data = fetch_20newsgroups(remove=('headers', 'footers', 'quotes'))\n",
        "documents = random.sample(data.data, 2000)\n",
        "\n",
        "# Preprocessing\n",
        "stop_words = set(stopwords.words('english'))\n",
        "\n",
        "def preprocess(text):\n",
        "    text = text.lower()\n",
        "    text = re.sub(r'\\W+', ' ', text)\n",
        "    words = text.split()\n",
        "    words = [w for w in words if w not in stop_words]\n",
        "    return \" \".join(words)\n",
        "\n",
        "processed_docs = [preprocess(doc) for doc in documents]\n",
        "\n",
        "# Vectorization\n",
        "vectorizer = CountVectorizer(max_features=1000)\n",
        "X = vectorizer.fit_transform(processed_docs)\n",
        "feature_names = vectorizer.get_feature_names_out()\n",
        "\n",
        "# Function to extract topics\n",
        "def get_topics(model, feature_names, n_top_words=10):\n",
        "    topics = []\n",
        "    for topic in model.components_:\n",
        "        words = [feature_names[i] for i in topic.argsort()[-n_top_words:]]\n",
        "        topics.append(words)\n",
        "    return topics\n",
        "\n",
        "# Print topics\n",
        "def print_topics(topics, title):\n",
        "    print(f\"\\n{title}\")\n",
        "    for i, topic in enumerate(topics):\n",
        "        print(f\"Topic {i+1}: {topic}\")\n",
        "\n",
        "# Prepare for coherence\n",
        "texts = [doc.split() for doc in processed_docs]\n",
        "dictionary = Dictionary(texts)\n",
        "\n",
        "def compute_coherence(topics):\n",
        "    coherence_model = CoherenceModel(\n",
        "        topics=topics,\n",
        "        texts=texts,\n",
        "        dictionary=dictionary,\n",
        "        coherence='c_v'\n",
        "    )\n",
        "    return coherence_model.get_coherence()\n",
        "\n",
        "# LDA with K=10\n",
        "lda = LatentDirichletAllocation(n_components=10, random_state=42)\n",
        "lda.fit(X)\n",
        "lda_topics_10 = get_topics(lda, feature_names)\n",
        "print_topics(lda_topics_10, \"LDA Topics (K=10)\")\n",
        "\n",
        "# LSA with K=10\n",
        "lsa = TruncatedSVD(n_components=10, random_state=42)\n",
        "lsa.fit(X)\n",
        "lsa_topics_10 = get_topics(lsa, feature_names)\n",
        "print_topics(lsa_topics_10, \"LSA Topics (K=10)\")\n",
        "\n",
        "# Coherence for K=10\n",
        "lda_coherence_10 = compute_coherence(lda_topics_10)\n",
        "lsa_coherence_10 = compute_coherence(lsa_topics_10)\n",
        "\n",
        "print(f\"\\nLDA Coherence (K=10): {lda_coherence_10}\")\n",
        "print(f\"LSA Coherence (K=10): {lsa_coherence_10}\")\n",
        "\n",
        "# Find optimal K\n",
        "k_values = range(5, 16)\n",
        "lda_scores = []\n",
        "lsa_scores = []\n",
        "\n",
        "for k in k_values:\n",
        "    lda = LatentDirichletAllocation(n_components=k, random_state=42)\n",
        "    lda.fit(X)\n",
        "    lda_topics = get_topics(lda, feature_names)\n",
        "    lda_scores.append(compute_coherence(lda_topics))\n",
        "\n",
        "    lsa = TruncatedSVD(n_components=k, random_state=42)\n",
        "    lsa.fit(X)\n",
        "    lsa_topics = get_topics(lsa, feature_names)\n",
        "    lsa_scores.append(compute_coherence(lsa_topics))\n",
        "\n",
        "# Plot coherence scores\n",
        "plt.figure(figsize=(10,5))\n",
        "plt.plot(k_values, lda_scores, marker='o', label='LDA')\n",
        "plt.plot(k_values, lsa_scores, marker='o', label='LSA')\n",
        "\n",
        "plt.xlabel(\"Number of Topics (K)\")\n",
        "plt.ylabel(\"Coherence Score\")\n",
        "plt.title(\"Coherence Score vs Number of Topics\")\n",
        "plt.legend()\n",
        "plt.grid()\n",
        "plt.show()\n",
        "\n",
        "# Best K\n",
        "best_lda_k = k_values[np.argmax(lda_scores)]\n",
        "best_lsa_k = k_values[np.argmax(lsa_scores)]\n",
        "\n",
        "print(f\"\\nOptimal K for LDA: {best_lda_k}\")\n",
        "print(f\"Optimal K for LSA: {best_lsa_k}\")"
      ]
    },
